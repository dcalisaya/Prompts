# Configuración para Live Developer - Cloud-Only
# Copiar a .env y completar valores
# Esta versión NO requiere Ollama, solo APIs pagadas

# === OpenAI (Obligatorio para cloud-only) ===
OPENAI_API_KEY=sk-proj-...

# === Anthropic (Opcional, recomendado) ===
ANTHROPIC_API_KEY=sk-ant-...

# === OpenRouter (Opcional - acceso a más modelos) ===
OPENROUTER_API_KEY=sk-or-...

# === LiteLLM ===
LITELLM_MASTER_KEY=sk-ld-cloud-prod-key

# === Open WebUI OAuth (Opcional - para auth vía Google/Microsoft) ===
# Para configurar OAuth con Google:
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Crea OAuth 2.0 credentials
# 3. Configura redirect URI: http://tu-vm:3000/oauth/google/callback

OAUTH_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=tu-google-client-secret
OPENID_PROVIDER_URL=https://accounts.google.com/.well-known/openid-configuration
OAUTH_SCOPES=openid email profile

# === Configuración General ===
DEFAULT_LOCALE=es
ENABLE_SIGNUP=true

# === Budget Alerts (Opcional) ===
# Recibe alertas cuando se acerque al límite
BUDGET_ALERT_EMAIL=admin@livedeveloper.com
