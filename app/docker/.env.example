# Configuración para Live Developer Local LLM Stack
# Copiar a .env y completar valores

# API Keys para fallback (opcional pero recomendado)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Master key para LiteLLM (generar uno seguro)
LITELLM_MASTER_KEY=sk-ld-local-dev-key

# Configuración de Ollama
OLLAMA_HOST=http://host.docker.internal:11434

# Configuración Open WebUI
WEBUI_SECRET_KEY=tu-secret-key-aqui
ENABLE_SIGNUP=true
DEFAULT_LOCALE=es

# Langfuse para tracking (opcional)
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_SECRET_KEY=...
LANGFUSE_HOST=https://cloud.langfuse.com
