---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="¡Gracias! | Live Developer">
	<main class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center">
		<div class="space-y-8 animate-in fade-in zoom-in duration-700">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-primary/10 border border-primary/20 text-primary mb-4">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      
			<h1 class="text-5xl md:text-6xl font-bold font-heading">¡Solicitud Enviada!</h1>
			<p class="text-xl text-muted max-w-lg mx-auto font-body leading-relaxed">
				Hemos recibido su información correctamente. Un especialista de nuestro equipo revisará su caso para preparar el diagnóstico inicial.
			</p>

      <div class="pt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-8 py-4 bg-surface border border-border rounded-xl font-bold hover:border-primary transition-all">
          Volver al Inicio
        </a>
        <a href="/tecnologica" class="px-8 py-4 bg-primary text-background rounded-xl font-bold hover:opacity-90 transition-all">
          Seguir Explorando
        </a>
      </div>
		</div>
	</main>
</MainLayout>
