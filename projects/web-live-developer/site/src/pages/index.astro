---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Live Developer | Ingeniería y Narrativa Integradas">
	<main class="relative min-h-[calc(100vh-80px)] flex flex-col items-center justify-center overflow-hidden">
		
    <!-- Background Elements -->
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-[120px] animate-pulse delay-700"></div>
    </div>

    <div class="relative z-10 w-full max-w-7xl px-4 py-12 text-center">
			<header class="mb-16 space-y-6">
        <div class="inline-block px-4 py-1.5 rounded-full border border-border bg-surface/50 text-xs font-bold tracking-widest uppercase text-muted mb-4">
          Hub de Soluciones B2B
        </div>
				<h1 class="text-6xl md:text-8xl font-bold font-heading tracking-tight leading-tight">
					Donde la <span class="text-primary italic">Razón</span> <br class="hidden md:block" /> 
          encuentra la <span class="text-accent">Emoción</span>
				</h1>
				<p class="text-xl md:text-2xl text-muted max-w-3xl mx-auto font-body leading-relaxed">
					Ingeniería de software avanzada y narrativa audiovisual de alto nivel. 
          <span class="text-content font-medium">No elegimos un camino, integramos todos.</span>
				</p>
			</header>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
				<!-- Track Selector: Creativa -->
				<a 
					href="/creativa"
					class="group relative flex flex-col items-center p-8 rounded-3xl bg-surface/30 border border-border/50 backdrop-blur-sm transition-all hover:scale-[1.02] hover:border-accent/50 hover:bg-surface/50 overflow-hidden"
					id="selector-creativa"
				>
					<div class="relative z-20 text-center">
            <span class="text-accent text-xs font-bold uppercase tracking-widest mb-4 block group-hover:translate-y-[-4px] transition-transform">Área Creativa</span>
						<h2 class="text-3xl font-bold font-heading mb-4 text-content">Narrativa</h2>
						<p class="text-muted text-sm leading-relaxed">Producción audiovisual y branding para marcas que trascienden.</p>
					</div>
					<div class="absolute inset-0 bg-gradient-to-br from-accent/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
				</a>

				<!-- Track Selector: Tecnológica -->
				<a 
					href="/tecnologica"
					class="group relative flex flex-col items-center p-8 rounded-3xl bg-surface/30 border border-border/50 backdrop-blur-sm transition-all hover:scale-[1.02] hover:border-primary/50 hover:bg-surface/50 overflow-hidden"
					id="selector-tecnologica"
				>
					<div class="relative z-20 text-center">
            <span class="text-primary text-xs font-bold uppercase tracking-widest mb-4 block group-hover:translate-y-[-4px] transition-transform">Área Tecnológica</span>
						<h2 class="text-3xl font-bold font-heading mb-4 text-content">Ingeniería</h2>
						<p class="text-muted text-sm leading-relaxed">Software a medida y arquitectura de IA para operaciones de alto nivel.</p>
					</div>
					<div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
				</a>

        <!-- Track Selector: Consultoría -->
				<a 
					href="/consultoria"
					class="group relative flex flex-col items-center p-8 rounded-3xl bg-surface/30 border border-border/50 backdrop-blur-sm transition-all hover:scale-[1.02] hover:border-content/50 hover:bg-surface/50 overflow-hidden"
					id="selector-consultoria"
				>
					<div class="relative z-20 text-center">
            <span class="text-content text-xs font-bold uppercase tracking-widest mb-4 block group-hover:translate-y-[-4px] transition-transform">Estrategia</span>
						<h2 class="text-3xl font-bold font-heading mb-4 text-content">Negocio</h2>
						<p class="text-muted text-sm leading-relaxed">Consultoría de negocio y CX para acelerar el crecimiento real.</p>
					</div>
					<div class="absolute inset-0 bg-gradient-to-br from-content/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
				</a>
			</div>
		</div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce text-muted opacity-50">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 13 5 5 5-5M7 6l5 5 5-5"/></svg>
    </div>
	</main>

	<script>
		// Handle track selection persistence
		const creativeBtn = document.getElementById('selector-creativa');
		const techBtn = document.getElementById('selector-tecnologica');
    const consultBtn = document.getElementById('selector-consultoria');

		creativeBtn?.addEventListener('click', () => {
			localStorage.setItem('ld_track', 'creativa');
		});

		techBtn?.addEventListener('click', () => {
			localStorage.setItem('ld_track', 'tecnologica');
		});

    consultBtn?.addEventListener('click', () => {
			localStorage.setItem('ld_track', 'consultoria');
		});
	</script>
</MainLayout>
