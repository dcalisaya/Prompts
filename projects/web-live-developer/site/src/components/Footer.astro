---
import catalog from '../data/services.json';

const categories = catalog.categories;

// Divide categories for columns (3 cols)
const perCol = Math.ceil(categories.length / 3);
const col1 = categories.slice(0, perCol);
const col2 = categories.slice(perCol, perCol * 2);
const col3 = categories.slice(perCol * 2);
---

<footer class="bg-surface border-t border-border mt-32 pt-20 pb-12">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-20">
      
      <!-- Brand & DNA -->
      <div class="lg:col-span-2 pr-8">
        <a href="/" class="text-2xl font-bold font-heading text-primary mb-6 block hover:opacity-80 transition-opacity">
          Live Developer
        </a>
        <p class="text-muted text-sm mb-8 leading-relaxed max-w-sm">
          Fusión estratégica de ingeniería de software y narrativa de impacto. Construimos los sistemas y contamos las historias que definen el futuro de su organización.
        </p>
        <div class="flex gap-4">
          <a href="https://linkedin.com" class="w-10 h-10 rounded-xl bg-background border border-border flex items-center justify-center text-muted hover:text-primary hover:border-primary/50 transition-all" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://instagram.com" class="w-10 h-10 rounded-xl bg-background border border-border flex items-center justify-center text-muted hover:text-accent hover:border-accent/50 transition-all" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
        </div>
      </div>

      <!-- Services Navigation -->
      <div class="lg:col-span-3">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-content mb-8 opacity-50">Ecosistema de Servicios</h4>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          <ul class="space-y-4">
            {col1.map(cat => (
              <li><a href="#" class="text-xs font-medium text-muted hover:text-content transition-colors">{cat}</a></li>
            ))}
          </ul>
          <ul class="space-y-4">
            {col2.map(cat => (
              <li><a href="#" class="text-xs font-medium text-muted hover:text-content transition-colors">{cat}</a></li>
            ))}
          </ul>
          <ul class="space-y-4">
            {col3.map(cat => (
              <li><a href="#" class="text-xs font-medium text-muted hover:text-content transition-colors">{cat}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Contact & Legal -->
    <div class="pt-12 border-t border-border flex flex-col lg:flex-row justify-between items-start lg:items-center gap-8">
      <div class="flex flex-col sm:flex-row gap-8 text-xs font-bold uppercase tracking-widest text-muted">
        <div class="flex items-center gap-3">
          <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></div>
          <span>Quito, Ecuador</span>
        </div>
        <a href="mailto:hola@livedeveloper.com" class="hover:text-primary transition-colors">hola@livedeveloper.com</a>
      </div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="flex gap-6 text-[10px] font-bold uppercase tracking-widest text-muted/60">
          <a href="#" class="hover:text-content transition-colors">Privacidad</a>
          <a href="#" class="hover:text-content transition-colors">Términos</a>
        </div>
        <p class="text-[10px] font-medium text-muted/40">
          &copy; 2026 Live Developer. Parte de EJECOM S.A.S.
        </p>
      </div>
    </div>
  </div>
</footer>
